# Client-safe configuration exposed to the browser via config.js in Docker

# EmailJS service ID used by the contact form and visitor notification template
EMAILJS_SERVICE_ID=

# EmailJS template ID used for visitor notification emails
EMAILJS_TEMPLATE_ID=

# EmailJS template ID used by the contact form submission flow
EMAILJS_CONTACT_TEMPLATE_ID=

# EmailJS public key used by browser-side EmailJS requests
EMAILJS_PUBLIC_KEY=

# Google reCAPTCHA site key used by the public contact form
RECAPTCHA_SITE_KEY=

# Enables extra visitor-tracking logs during development when set to true
DEBUG_VISITOR_TRACKING=false

# Public API base URL exposed to the client application
API_URL=http://localhost:3000

# Visitor tracking is disabled unless explicitly enabled
ENABLE_VISITOR_TRACKING=false
