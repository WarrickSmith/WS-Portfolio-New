# Docker/Portainer stack environment variables
# Copy this file to stack.env and provide values before deploying.
# These are the client-safe keys written into /app/dist/config.js by docker-entrypoint.sh.

# EmailJS configuration
EMAILJS_SERVICE_ID=service_xxxxxx
EMAILJS_TEMPLATE_ID=template_visitor_xxxx
EMAILJS_CONTACT_TEMPLATE_ID=template_contact_xxxx
EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxx

# reCAPTCHA configuration
RECAPTCHA_SITE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public API / site URL
API_URL=https://ws.wsapz.com

# Visitor tracking controls
DEBUG_VISITOR_TRACKING=false
ENABLE_VISITOR_TRACKING=false
